<% if notice.present? %>
  <div popover class="flash" style="--flash-position: 5rem;" data-controller="element-removal" data-action="animationend->element-removal#remove" role="alert"><%= notice %></div>
<% end %>

<% content_for :title, "Races" %>

<div class="flex items-center justify-between mbe-4">
  <h1 class="font-bold text-4xl">Races</h1>
  <%= link_to "New race", new_race_path, class: "btn btn--primary" %>
</div>

<div class="races-list">
  <% @races.each do |race| %>
    <% distance_data = COMMON_RACE_DISTANCES[race.distance.to_s] %>
    <% race_color = distance_data ? distance_data[:colors][:dark] : "var(--color-accent)" %>
    <% race_color_light = distance_data ? distance_data[:colors][:light] : "var(--color-accent-light)" %>
    <%= link_to race, class: "race-card", style: "--race-color: #{race_color}; --race-color-light: #{race_color_light}" do %>
      <div class="race-card-header">
        <span class="race-card-distance"><%= distance_data ? distance_data[:name] : decorated_distance_for(race.distance) %></span>
      </div>
      <h3 class="race-card-name"><%= race.name %></h3>
      <p class="race-card-location"><%= race.location %></p>
      <% best = race.runs.where(user: current_user).order(time: :asc).first %>
      <% if best %>
        <div class="race-card-best">
          <span class="race-card-best-label">Best</span>
          <span class="race-card-best-time"><%= decorated_time_for(best.time) %></span>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
