<%= form_with(model: race, html: { contents: true }) do |form| %>
  <% if race.errors.any? %>
    <div class="alert alert--negative flex flex-col gap-half mbe-4" role="alert">
      <h2 class="font-medium leading-none"><%= pluralize(race.errors.count, "error") %> prohibited this race from being saved:</h2>

      <ul class="text-sm mis-3" style="list-style: disc">
        <% race.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @existing_race %>
    <div class="alert mbe-4" role="alert">
      A race with this name already exists.
      <%= link_to "View #{@existing_race.name} →", @existing_race, class: "font-medium" %>
    </div>
  <% end %>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :name, class: "text-sm font-medium leading-none" %>
    <%= form.text_field :name, class: "input" %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :location, class: "text-sm font-medium leading-none" %>
    <%= form.text_field :location, class: "input" %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :distance, class: "text-sm font-medium leading-none" %>
    <%= text_field_tag "race[distance]", nil, list: "common_distances", class: "input" %>
    <%= tag.datalist options_for_select(COMMON_RACE_DISTANCES.map { [_2[:name], _1]}), id: "common_distances" %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :certificate_number, class: "text-sm font-medium leading-none" %>
    <%= form.text_field :certificate_number, class: "input", placeholder: "e.g. RFEA-2024-1234" %>
  </div>

  <div class="inline-flex items-center mbs-2 mie-1">
    <%= form.submit class: "btn btn--primary" %>
  </div>
<% end %>
