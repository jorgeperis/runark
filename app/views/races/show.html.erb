<% if notice.present? %>
  <div popover class="flash" style="--flash-position: 5rem;" data-controller="element-removal" data-action="animationend->element-removal#remove" role="alert"><%= notice %></div>
<% end %>

<h1 class="font-bold text-3xl mbe-4"><%= @race.name %></h1>

<%= render @race %>

<% if @race.certificate_number.present? %>
  <p class="text-sm mbs-2"><%= t("races.show.certificate") %> <span class="font-medium"><%= @race.certificate_number %></span></p>
<% end %>

<div class="flex flex-wrap items-center gap" style="--row-gap: .5rem">
  <%= link_to t("races.show.edit_this_race"), edit_race_path(@race), class: "btn" %>
  <%= link_to t("races.show.back_to_races"), races_path, class: "btn" %>
  <%= button_to t("races.show.destroy_this_race"), @race, method: :delete, class: "btn" %>
</div>

<% if current_user.admin? %>
  <div class="mbs-4 flex items-center gap">
    <%= form_with url: merge_race_path(@race), method: :post, data: { turbo_confirm: t("races.show.merge_confirm", name: @race.name) } do |f| %>
      <% other_races = Race.canonical.where.not(id: @race.id).where(distance: @race.distance).order(:name) %>
      <%= f.select :target_id, options_from_collection_for_select(other_races, :id, :name),
          { include_blank: t("races.show.select_merge") },
          class: "input" %>
      <%= f.submit t("races.show.merge"), class: "btn btn--primary" %>
    <% end %>
  </div>
<% end %>

<p class="font-bold text-2xl mbs-6"><%= t("races.show.runs") %></p>

<table class="table mbs-4">
  <thead>
    <tr>
      <th><%= t("runs.table.name") %></th>
      <th><%= t("runs.table.date") %></th>
      <th><%= t("runs.table.distance") %></th>
      <th><%= t("runs.table.time") %></th>
      <th><%= t("runs.table.pace") %></th>
    </tr>
  </thead>
  <tbody>
    <% @race.runs.where(user: current_user).ordered.each do |run| %>
      <div class="flex flex-col items-start gap">
        <tr>
          <th><%= link_to run.full_name, run %></th>
          <td><%= l(run.date, format: :long_day) %></td>
          <td><%= decorated_distance_for(run.distance) %></td>
          <td><%= decorated_time_for(run.time) %></td>
          <td><%= decorated_time_for(run.pace) %></td>
        </tr>
      </div>
    <% end %>
</table>
