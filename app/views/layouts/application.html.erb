<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "Runark" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="theme-color" content="#F43F8E">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Runark">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400;1,700&family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "css-zero/reset", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "css-zero/variables", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "css-zero/utilities", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="header-layout">
    <header id="header">
      <div class="container flex items-center justify-between">
        <div class="flex items-center">
          <%= link_to stats_path, class: "header-logo" do %>
            <svg class="header-logo-icon" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="1" y="1" width="46" height="46" fill="#F43F8E" stroke="#18181C" stroke-width="2"/>
              <g fill="none" stroke="#18181C" stroke-width="6" stroke-linecap="butt" stroke-linejoin="miter">
                <path d="M15 13 V36"/>
                <path d="M15 13 H30 V24 H15"/>
                <path d="M22 24 L31 36"/>
              </g>
            </svg>
            <span class="header-logo-text">Runark</span>
          <% end %>
          <nav>
            <ul class="flex items-center mis-6" style="gap: 4px">
              <li><%= link_to t("nav.stats"), stats_path, class: "nav-link #{current_page?(stats_path) ? 'nav-link--active' : ''}" %></li>
              <li><%= link_to t("nav.races"), races_path, class: "nav-link #{current_page?(races_path) ? 'nav-link--active' : ''}" %></li>
              <li><%= link_to t("nav.runs"), runs_path, class: "nav-link #{current_page?(runs_path) ? 'nav-link--active' : ''}" %></li>
            </ul>
          </nav>
        </div>
        <div class="flex items-center" style="gap: var(--size-3)">
          <div class="locale-switch" role="group" aria-label="<%= t("nav.language") %>">
            <% I18n.available_locales.each do |loc| %>
              <%= button_to loc.to_s.upcase, locale_path(loc), method: :put,
                    form_class: "locale-switch__form",
                    class: "locale-switch__btn #{'is-active' if I18n.locale == loc}" %>
            <% end %>
          </div>
          <% if Current.user %>
            <%= link_to Current.user.email_address, edit_profile_path, class: "text-sm mie-4 user-email" %>
            <%= button_to t("nav.log_out"), session_path, method: :delete, class: "btn btn--secondary" %>
          <% else %>
            <%= link_to t("nav.log_in"), new_session_path, class: "btn btn--primary" %>
          <% end %>
        </div>
      </div>
    </header>

    <main id="main">
      <% if notice.present? %>
        <div popover class="flash" style="--flash-position: 5rem;" data-controller="element-removal" data-action="animationend->element-removal#remove" role="alert"><%= notice %></div>
      <% end %>
      <div class="container">
        <%= yield %>
      </div>
    </main>

    <nav id="bottom-nav">
      <%= link_to stats_path, class: ("active" if current_page?(stats_path)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
        </svg>
        <%= t("nav.stats") %>
      <% end %>
      <%= link_to races_path, class: ("active" if current_page?(races_path)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0" />
        </svg>
        <%= t("nav.races") %>
      <% end %>
      <%= link_to runs_path, class: ("active" if current_page?(runs_path)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <%= t("nav.runs") %>
      <% end %>
    </nav>
  </body>
</html>
