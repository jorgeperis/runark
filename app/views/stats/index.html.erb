<% content_for :title, "Stats" %>

<div class="stats-header">
  <h1 class="stats-title">Your Stats</h1>
  <p class="stats-subtitle">Track your running journey</p>
</div>

<section class="stats-section stats-section--highlight">
  <div class="stats-section-header">
    <h2 class="stats-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="stats-section-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0" />
      </svg>
      Personal Bests
    </h2>
    <span class="stats-section-badge">Homologated races</span>
  </div>

  <div class="pb-grid">
    <% @best_marks.each do |run_mark| %>
      <% distance_data = COMMON_RACE_DISTANCES[run_mark.distance.to_s] %>
      <%= link_to run_mark, class: "pb-card", style: "--pb-color: #{distance_data[:colors][:dark]}; --pb-color-light: #{distance_data[:colors][:light]}" do %>
        <div class="pb-card-distance"><%= distance_data[:name] %></div>
        <div class="pb-card-time"><%= decorated_time_for(run_mark.time) %></div>
        <div class="pb-card-pace">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="pb-card-pace-icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
          <%= decorated_time_for(run_mark.pace) %>/km
        </div>
        <div class="pb-card-date"><%= run_mark.date.strftime("%b %Y") %></div>
      <% end %>
    <% end %>
  </div>
</section>

<section class="stats-section">
  <div class="stats-section-header">
    <h2 class="stats-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="stats-section-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
      </svg>
      Estimated Paces
    </h2>
  </div>
  <% if @last_homologated %>
  <% run_mark = @last_homologated %>
  <p class="stats-section-description">Based on <%= run_mark.full_name %></p>
  <div class="estimated-paces-list">
    <% EstimatedPaces.for(run_mark).each do |distance, time| %>
      <% distance_data = COMMON_RACE_DISTANCES[distance] %>
      <div class="estimated-pace-item" style="--ep-color: <%= distance_data[:colors][:dark] %>">
        <span class="estimated-pace-distance"><%= distance_data[:name] %></span>
        <span class="estimated-pace-time"><%= decorated_time_for(time) %></span>
        <span class="estimated-pace-per-km"><%= decorated_time_for((time / distance.to_f).round) %>/km</span>
      </div>
    <% end %>
  </div>
  <% end %>
</section>

<section class="stats-section">
  <div class="stats-section-header">
    <h2 class="stats-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="stats-section-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" />
      </svg>
      Top 3 by Distance
    </h2>
  </div>

  <div class="top-three-rows">
    <% FAVOURITE_RACE_DISTANCES.each do |distance, distance_data| %>
      <div class="top-three-row" style="--tt-color: <%= distance_data[:colors][:dark] %>; --tt-color-light: <%= distance_data[:colors][:light] %>">
        <h3 class="top-three-row-title"><%= distance_data[:name] %></h3>
        <div class="top-three-items">
          <% @top_marks_by_distance[distance].each_with_index do |run_mark, index| %>
            <%= link_to run_mark, class: "top-three-item" do %>
              <span class="top-three-rank"><%= index + 1 %></span>
              <div class="top-three-info">
                <span class="top-three-time"><%= decorated_time_for(run_mark.time) %></span>
                <span class="top-three-pace"><%= decorated_time_for(run_mark.pace) %>/km</span>
              </div>
              <span class="top-three-name"><%= run_mark.full_name %></span>
              <span class="top-three-date"><%= run_mark.date.strftime("%d %b %Y") %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
