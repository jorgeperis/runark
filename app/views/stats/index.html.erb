<% content_for :title, "Stats" %>

<div class="stats-header">
  <h1 class="stats-title">Your Stats</h1>
  <p class="stats-subtitle">Track your running journey</p>
</div>

<section class="stats-numbers">
  <div class="stats-number">
    <span class="stats-number-value"><%= @total_races %></span>
    <span class="stats-number-label">Races</span>
  </div>
  <div class="stats-number">
    <span class="stats-number-value"><%= number_with_delimiter(@total_distance.round) %><span class="stats-number-unit">km</span></span>
    <span class="stats-number-label">Distance raced</span>
  </div>
  <div class="stats-number">
    <span class="stats-number-value"><%= (@total_time / 3600.0).round(1) %><span class="stats-number-unit">h</span></span>
    <span class="stats-number-label">Time racing</span>
  </div>
  <div class="stats-number">
    <span class="stats-number-value"><%= @races_this_year %></span>
    <span class="stats-number-label">In <%= Date.current.year %></span>
  </div>
</section>

<section class="stats-section stats-section--highlight">
  <div class="stats-section-header">
    <h2 class="stats-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="stats-section-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0" />
      </svg>
      Personal Bests
    </h2>
  </div>

  <div class="pb-grid">
    <% @best_marks.each do |run| %>
      <% distance_data = COMMON_RACE_DISTANCES[run.distance.to_s] %>
      <%= link_to run, class: "pb-card #{"pb-card--has-photo" if run.image.attached?}", style: "--pb-color: #{distance_data[:colors][:dark]}; --pb-color-light: #{distance_data[:colors][:light]}" do %>
        <% if run.image.attached? %>
          <%= image_tag run.image.variant(resize_to_fill: [ 600, 400 ]), class: "pb-card-photo", loading: "lazy", alt: "" %>
        <% end %>
        <div class="pb-card-heading">
          <div class="pb-card-distance"><%= distance_data[:name] %></div>
          <div class="pb-card-name"><%= run.race.name %></div>
        </div>
        <div class="pb-card-time"><%= decorated_time_for(run.time) %></div>
        <div class="pb-card-pace">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="pb-card-pace-icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
          <%= decorated_time_for(run.pace) %>/km
        </div>
        <div class="pb-card-date"><%= run.date.strftime("%b %Y") %></div>
      <% end %>
    <% end %>
  </div>
</section>

<section class="stats-section">
  <div class="stats-section-header">
    <h2 class="stats-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="stats-section-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0" />
      </svg>
      Performance Score
    </h2>
    <span class="stats-section-badge">Age-graded</span>
  </div>

  <% if !current_user.profile_complete? %>
    <p class="stats-section-description">
      <%= link_to "Add your sex and date of birth", edit_profile_path %> to unlock age-graded performance scoring.
    </p>
  <% elsif !@scoring_available %>
    <p class="stats-section-description">Scoring tables are being added — your age-graded performance will appear here soon.</p>
  <% else %>
    <div class="estimated-paces-list">
      <% @best_marks.each do |run| %>
        <% score = AgeGrading.for(run, current_user) %>
        <% next if score.nil? %>
        <% distance_data = COMMON_RACE_DISTANCES[run.distance.to_s] %>
        <div class="estimated-pace-item" style="--ep-color: <%= distance_data[:colors][:dark] %>">
          <span class="estimated-pace-distance"><%= distance_data[:name] %></span>
          <span class="estimated-pace-time"><%= decorated_time_for(run.time) %></span>
          <span class="estimated-pace-per-km"><%= number_to_percentage(score, precision: 1) %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

<section class="stats-section">
  <div class="stats-section-header">
    <h2 class="stats-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="stats-section-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.307a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
      </svg>
      Progression
    </h2>
    <span class="stats-section-badge">Best time per year</span>
  </div>

  <% progressions = @progression.select { |_, entries| entries.size >= 2 } %>
  <% if progressions.any? %>
    <div class="progression-list">
      <% progressions.each do |distance, entries| %>
        <% distance_data = COMMON_RACE_DISTANCES[distance] %>
        <% runs = entries.map(&:last) %>
        <% chart = progression_chart(entries.map { |year, run| [ year, run.time ] }, width: 280, height: 64) %>
        <% delta = runs.last.time - runs.first.time %>
        <div class="progression-row" style="--pr-color: <%= distance_data[:colors][:dark] %>; --pr-color-light: <%= distance_data[:colors][:light] %>">
          <div class="progression-meta">
            <span class="progression-distance"><%= distance_data[:name] %></span>
            <span class="progression-delta <%= delta <= 0 ? "is-faster" : "is-slower" %>">
              <%= delta <= 0 ? "−" : "+" %><%= decorated_time_for(delta.abs) %>
            </span>
          </div>
          <svg class="progression-chart" viewBox="0 0 280 64" role="img"
               aria-label="<%= distance_data[:name] %> best times from <%= entries.first.first %> to <%= entries.last.first %>">
            <polyline points="<%= chart[:line] %>" fill="none" stroke="var(--pr-color)" stroke-width="2"
                      stroke-linejoin="round" stroke-linecap="round" vector-effect="non-scaling-stroke" />
            <% chart[:points].each_with_index do |p, i| %>
              <% run = runs[i] %>
              <a href="<%= run_path(run) %>" class="progression-point">
                <title><%= run.full_name %> · <%= decorated_time_for(run.time) %></title>
                <circle cx="<%= p[:x] %>" cy="<%= p[:y] %>" r="11" fill="transparent" />
                <circle class="progression-dot" cx="<%= p[:x] %>" cy="<%= p[:y] %>" r="3.5"
                        fill="var(--pr-color)" stroke="#fff" stroke-width="2" vector-effect="non-scaling-stroke" />
              </a>
            <% end %>
          </svg>
          <div class="progression-years">
            <span><%= entries.first.first %> · <%= decorated_time_for(runs.first.time) %></span>
            <span><%= entries.last.first %> · <%= decorated_time_for(runs.last.time) %></span>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="stats-section-description">Race a distance in two or more years to see your progression here.</p>
  <% end %>
</section>

<section class="stats-section">
  <div class="stats-section-header">
    <h2 class="stats-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="stats-section-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5" />
      </svg>
      This Season
    </h2>
    <span class="stats-section-badge"><%= Date.current.year %></span>
  </div>

  <% seasonal = @season.select { |_, data| data[:current].present? } %>
  <% if seasonal.any? %>
    <div class="season-grid">
      <% seasonal.each do |distance, data| %>
        <% distance_data = COMMON_RACE_DISTANCES[distance] %>
        <% current = data[:current] %>
        <% previous = data[:previous] %>
        <div class="season-card" style="--season-color: <%= distance_data[:colors][:dark] %>; --season-color-light: <%= distance_data[:colors][:light] %>">
          <span class="season-distance"><%= distance_data[:name] %></span>
          <%= link_to decorated_time_for(current.time), current, class: "season-time" %>
          <% if previous %>
            <% delta = current.time - previous.time %>
            <span class="season-delta <%= delta <= 0 ? "is-faster" : "is-slower" %>">
              <%= delta <= 0 ? "▼" : "▲" %> <%= decorated_time_for(delta.abs) %> vs <%= previous.date.year %>
            </span>
          <% else %>
            <span class="season-delta season-delta--new">No <%= Date.current.year - 1 %> result</span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="stats-section-description">No races yet in <%= Date.current.year %>. Your season bests will show up here.</p>
  <% end %>
</section>

<section class="stats-section">
  <div class="stats-section-header">
    <h2 class="stats-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="stats-section-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
      </svg>
      Estimated Paces
    </h2>
  </div>
  <% if @last_run %>
  <% run = @last_run %>
  <p class="stats-section-description">Based on <%= run.full_name %></p>
  <div class="estimated-paces-list">
    <% EstimatedPaces.for(run, @favourite_distances.keys).each do |distance, time| %>
      <% distance_data = COMMON_RACE_DISTANCES[distance] %>
      <div class="estimated-pace-item" style="--ep-color: <%= distance_data[:colors][:dark] %>">
        <span class="estimated-pace-distance"><%= distance_data[:name] %></span>
        <span class="estimated-pace-time"><%= decorated_time_for(time) %></span>
        <span class="estimated-pace-per-km"><%= decorated_time_for((time / distance.to_f).round) %>/km</span>
      </div>
    <% end %>
  </div>
  <% end %>
</section>

<section class="stats-section">
  <div class="stats-section-header">
    <h2 class="stats-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="stats-section-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
      </svg>
      Activity Calendar
    </h2>
  </div>

  <% calendar_years = @activity.keys.map { |year, _| year }.uniq.sort.reverse %>
  <% if calendar_years.any? %>
    <% max_count = @activity.values.max %>
    <div class="calendar-heatmap">
      <div class="calendar-row calendar-row--head">
        <span class="calendar-year-label"></span>
        <% Date::ABBR_MONTHNAMES.compact.each do |label| %>
          <span class="calendar-month-label"><%= label.first %></span>
        <% end %>
      </div>
      <% calendar_years.each do |year| %>
        <div class="calendar-row">
          <span class="calendar-year-label"><%= year %></span>
          <% (1..12).each do |month| %>
            <% count = @activity[[ year, format("%02d", month) ]] || 0 %>
            <% level = count.zero? ? 0 : ((count.to_f / max_count) * 3).ceil %>
            <span class="calendar-cell calendar-cell--l<%= level %>"
                  title="<%= "#{Date::MONTHNAMES[month]} #{year}: #{count} #{"race".pluralize(count)}" %>"></span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="stats-section-description">Log a race to start building your activity calendar.</p>
  <% end %>
</section>

<section class="stats-section">
  <div class="stats-section-header">
    <h2 class="stats-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="stats-section-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" />
      </svg>
      Top 3 by Distance
    </h2>
    <%= link_to "Edit distances", edit_profile_path, class: "stats-section-badge" %>
  </div>

  <div class="top-three-rows">
    <% @favourite_distances.each do |distance, distance_data| %>
      <div class="top-three-row" style="--tt-color: <%= distance_data[:colors][:dark] %>; --tt-color-light: <%= distance_data[:colors][:light] %>">
        <h3 class="top-three-row-title"><%= distance_data[:name] %></h3>
        <div class="top-three-items">
          <% @top_runs_by_distance[distance].each_with_index do |run, index| %>
            <%= link_to run, class: "top-three-item" do %>
              <span class="top-three-rank"><%= index + 1 %></span>
              <div class="top-three-info">
                <span class="top-three-time"><%= decorated_time_for(run.time) %></span>
                <span class="top-three-pace"><%= decorated_time_for(run.pace) %>/km</span>
              </div>
              <span class="top-three-name"><%= run.full_name %></span>
              <span class="top-three-date"><%= run.date.strftime("%d %b %Y") %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
