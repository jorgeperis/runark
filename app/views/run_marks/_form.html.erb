<%= form_with(model: run_mark, html: { contents: true }) do |form| %>
  <% if run_mark.errors.any? %>
    <div class="alert alert--negative flex flex-col gap-half mbe-4" role="alert">
      <h2 class="font-medium leading-none"><%= pluralize(run_mark.errors.count, "error") %> prohibited this run mark from being saved:</h2>

      <ul class="text-sm mis-3" style="list-style: disc">
        <% run_mark.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :race_id, class: "text-sm font-medium leading-none" %>
    <%= form.select :race_id, grouped_options_for_select(races_grouped_options, form.object.race_id), { include_blank: "Select race..." }, data: { controller: "combobox" } %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :date, class: "text-sm font-medium leading-none" %>
    <%= form.date_field :date, class: "input input--datepicker", data: { controller: "datepicker" } %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :distance, class: "text-sm font-medium leading-none" %>
    <%= form.number_field :distance, class: "input", step: "0.001", inputmode: :decimal %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :homologated, class: "text-sm font-medium leading-none" %>
    <%= form.checkbox :homologated, class: "switch" %>
  </div>

  <div class="flex flex-col gap-half mbe-4">
    <%= form.label :time, class: "text-sm font-medium leading-none" %>
    <div class="flex gap-half">
      <%= form.number_field :time_hours, class: "input", min: 0 %>
      <%= form.number_field :time_minutes, class: "input", min: 0, max: 59 %>
      <%= form.number_field :time_seconds, class: "input",min: 0, max: 59 %>
    </div>
  </div>

  <div class="inline-flex items-center mbs-2 mie-1">
    <%= form.submit class: "btn btn--primary" %>
  </div>
<% end %>
