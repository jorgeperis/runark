<% if @runs.any? %>
  <table class="table runs-table">
    <thead>
      <tr>
        <th><%= t("runs.table.name") %></th>
        <th><%= sort_link "date", t("runs.table.date") %></th>
        <th><%= sort_link "distance", t("runs.table.distance") %></th>
        <th><%= t("runs.table.time") %></th>
        <th><%= sort_link "pace", t("runs.table.pace") %></th>
      </tr>
    </thead>
    <tbody>
      <% @runs.each do |run| %>
        <% pb = @best_times[run.distance] == run.time %>
        <% distance_data = COMMON_RACE_DISTANCES[run.distance.to_s] %>
        <tr class="<%= "runs-table__row--pb" if pb %>">
          <th>
            <%= link_to run.full_name, run, class: "runs-table__name", data: { turbo_frame: "_top" } %>
            <% if pb %>
              <span class="runs-table__pb" title="<%= t("runs.table.pb_title") %>">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="runs-table__pb-icon">
                  <path fill-rule="evenodd" d="M5.166 2.621v.858c-1.035.148-2.059.33-3.071.543a.75.75 0 0 0-.584.859 6.753 6.753 0 0 0 6.138 5.6 6.73 6.73 0 0 0 2.743 1.346A6.707 6.707 0 0 1 9.279 15H8.54c-1.036 0-1.875.84-1.875 1.875V19.5h-.75a2.25 2.25 0 0 0-2.25 2.25c0 .414.336.75.75.75h15a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-2.25-2.25h-.75v-2.625c0-1.036-.84-1.875-1.875-1.875h-.739a6.706 6.706 0 0 1-1.112-3.173 6.73 6.73 0 0 0 2.743-1.347 6.753 6.753 0 0 0 6.139-5.6.75.75 0 0 0-.585-.858 47.077 47.077 0 0 0-3.07-.543V2.62a.75.75 0 0 0-.658-.744 49.22 49.22 0 0 0-6.093-.377c-2.063 0-4.096.128-6.093.377a.75.75 0 0 0-.657.744Zm0 2.629c0 1.196.312 2.32.857 3.294A5.266 5.266 0 0 1 3.16 5.337a45.6 45.6 0 0 1 2.006-.343v.256Zm13.5 0v-.256c.674.1 1.343.214 2.006.343a5.265 5.265 0 0 1-2.863 3.207 6.72 6.72 0 0 0 .857-3.294Z" clip-rule="evenodd" />
                </svg>
                <%= t("runs.table.pb") %>
              </span>
            <% end %>
          </th>
          <td data-label="<%= t("runs.table.date") %>"><%= l(run.date, format: :long_day) %></td>
          <td data-label="<%= t("runs.table.distance") %>">
            <% if distance_data %>
              <span class="distance-pill" style="--d-color: <%= distance_data[:colors][:dark] %>; --d-bg: <%= distance_data[:colors][:light] %>;"><%= distance_data[:name] %></span>
            <% else %>
              <%= decorated_distance_for(run.distance) %>
            <% end %>
          </td>
          <td data-label="<%= t("runs.table.time") %>" class="runs-table__time"><%= decorated_time_for(run.time) %></td>
          <td data-label="<%= t("runs.table.pace") %>" class="runs-table__pace"><%= decorated_time_for(run.pace) %>/km</td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="runs-empty">
    <p class="runs-empty__text"><%= t("runs.table.empty") %></p>
    <%= link_to t("runs.table.add_first"), new_run_path, class: "btn btn--primary" %>
  </div>
<% end %>
