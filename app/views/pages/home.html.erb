<%# Runark landing — neo-brutalist. Styles in app/assets/stylesheets/runark_landing.css %>

<%# ---------------------------------------------------------------- Top marquee %>
<div class="rk-marquee rk-marquee--lime">
  <div class="rk-marquee-track">
    <% 2.times do %>
      <span>RUNARK <b>✦</b> CADA CARRERA <b>✦</b> CADA RÉCORD <b>✦</b> 5K—42K <b>✦</b> PREDICCIÓN RIEGEL <b>✦</b> SIN EXCUSAS <b>✦</b> </span>
    <% end %>
  </div>
</div>

<%# ---------------------------------------------------------------- Nav %>
<nav class="rk-nav">
  <div class="rk-container rk-nav-inner">
    <a href="/" class="rk-logo">
      <svg class="rk-logo-mark" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="1" y="1" width="46" height="46" fill="#F43F8E" stroke="#0C0C0E" stroke-width="2"/>
        <g fill="none" stroke="#0C0C0E" stroke-width="6" stroke-linecap="butt" stroke-linejoin="miter">
          <path d="M15 13 V36"/>
          <path d="M15 13 H30 V24 H15"/>
          <path d="M22 24 L31 36"/>
        </g>
      </svg>
      <span class="rk-logo-text">Runark</span>
    </a>
    <%= link_to "Log in →", new_session_path, class: "rk-btn rk-btn--pink rk-btn--sm" %>
  </div>
</nav>

<%# ---------------------------------------------------------------- Hero %>
<section class="rk-hero">
  <div class="rk-container rk-hero-inner">
    <div class="rk-hero-text">
      <span class="rk-eyebrow">Para corredores que compiten</span>

      <h1 class="rk-headline">
        Cada<br>
        carrera.<br>
        Cada <span class="rk-hl-pink">récord</span><span class="rk-hl-stroke">.</span>
      </h1>

      <p class="rk-lead">
        Runark registra tus tiempos, destaca tus mejores marcas y predice tu tiempo de meta
        en cualquier distancia. Sin gráficas bonitas que no dicen nada. Solo tus números.
      </p>

      <div class="rk-cta-row">
        <%= link_to "Entrar en Runark →", new_session_path, class: "rk-btn rk-btn--pink" %>
        <a href="#features" class="rk-btn">Ver qué hace</a>
      </div>

      <div class="rk-data-row">
        <div class="rk-data-cell">
          <div class="rk-data-index">[01]</div>
          <div class="rk-data-num">5K—42K</div>
          <div class="rk-data-label">Toda distancia</div>
        </div>
        <div class="rk-data-cell">
          <div class="rk-data-index">[02]</div>
          <div class="rk-data-num">RIEGEL</div>
          <div class="rk-data-label">Predicción</div>
        </div>
        <div class="rk-data-cell">
          <div class="rk-data-index">[03]</div>
          <div class="rk-data-num">∞</div>
          <div class="rk-data-label">Historial</div>
        </div>
      </div>
    </div>

    <%# Mockup — raw bordered card, hard pink shadow, tilted %>
    <div class="rk-hero-visual">
      <div class="rk-mockup">
        <div class="rk-mockup-head">
          <div class="rk-mockup-title">// Mejores marcas</div>
          <span class="rk-mockup-live">En vivo</span>
        </div>

        <div class="rk-pb-grid">
          <div class="rk-pb-card">
            <div class="rk-pb-dist">5K</div>
            <div class="rk-pb-time">18:42</div>
            <div class="rk-pb-pace">3:44 /km</div>
          </div>
          <div class="rk-pb-card">
            <div class="rk-pb-dist">10K</div>
            <div class="rk-pb-time">38:55</div>
            <div class="rk-pb-pace">3:53 /km</div>
          </div>
          <div class="rk-pb-card">
            <div class="rk-pb-dist">Media</div>
            <div class="rk-pb-time">1:26:11</div>
            <div class="rk-pb-pace">4:05 /km</div>
          </div>
          <div class="rk-pb-card">
            <div class="rk-pb-dist">Maratón</div>
            <div class="rk-pb-time">3:08:22</div>
            <div class="rk-pb-pace">4:28 /km</div>
          </div>
        </div>

        <div class="rk-predict">
          <span class="rk-predict-label">Predicción 5K</span>
          <span class="rk-predict-badge">→ 18:28</span>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ---------------------------------------------------------------- Marquee divider %>
<div class="rk-marquee rk-marquee--rev">
  <div class="rk-marquee-track">
    <% 2.times do %>
      <span>PB <b>·</b> 5K <b>·</b> 10K <b>·</b> 15K <b>·</b> 10 MILLAS <b>·</b> MEDIA <b>·</b> 30K <b>·</b> MARATÓN <b>·</b> </span>
    <% end %>
  </div>
</div>

<%# ---------------------------------------------------------------- Features %>
<section class="rk-section rk-section--alt" id="features">
  <div class="rk-container">
    <div class="rk-section-head">
      <h2 class="rk-section-heading">Todo lo que necesita un corredor</h2>
      <p class="rk-section-label">// Qué hace Runark</p>
    </div>

    <div class="rk-features-grid">
      <div class="rk-card">
        <div class="rk-card-index">[01]</div>
        <div class="rk-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
        </div>
        <h3 class="rk-feature-title">Mejores marcas</h3>
        <p class="rk-feature-body">Tus tiempos más rápidos de 5K a maratón, siempre en primer plano. Sin scroll.</p>
      </div>

      <div class="rk-card">
        <div class="rk-card-index">[02]</div>
        <div class="rk-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
        </div>
        <h3 class="rk-feature-title">Predicción</h3>
        <p class="rk-feature-body">A partir de tu última carrera, Runark calcula tu tiempo estimado para cada distancia.</p>
      </div>

      <div class="rk-card">
        <div class="rk-card-index">[03]</div>
        <div class="rk-feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><rect x="3" y="4" width="18" height="18"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
        </div>
        <h3 class="rk-feature-title">Historial</h3>
        <p class="rk-feature-body">Cataloga cada carrera con nombre, lugar y fecha. No vuelvas a perder un tiempo.</p>
      </div>
    </div>
  </div>
</section>

<%# ---------------------------------------------------------------- CTA %>
<section class="rk-section">
  <div class="rk-container">
    <div class="rk-cta-panel">
      <h2 class="rk-cta-heading">¿Listo para<br>correr con cabeza?</h2>
      <p class="rk-cta-desc">// Empieza a registrar tus marcas hoy mismo</p>
      <%= link_to "Entrar en Runark →", new_session_path, class: "rk-btn rk-btn--ink" %>
    </div>
  </div>
</section>

<%# ---------------------------------------------------------------- Footer %>
<footer class="rk-footer">
  <div class="rk-container rk-footer-inner">
    <a href="/" class="rk-logo">
      <svg class="rk-logo-mark" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="1" y="1" width="46" height="46" fill="#F43F8E" stroke="#0C0C0E" stroke-width="2"/>
        <g fill="none" stroke="#0C0C0E" stroke-width="6" stroke-linecap="butt" stroke-linejoin="miter">
          <path d="M15 13 V36"/>
          <path d="M15 13 H30 V24 H15"/>
          <path d="M22 24 L31 36"/>
        </g>
      </svg>
      <span class="rk-logo-text">Runark</span>
    </a>
    <p class="rk-footer-text">© <%= Date.current.year %> Runark — Hecho para corredores</p>
  </div>
</footer>
