<h1 style="margin: 0 0 16px; font-size: 22px; font-weight: 800; letter-spacing: -0.02em; color: #18181b;"><%= t("passwords_mailer.reset.heading") %></h1>

<p style="margin: 0 0 24px; font-size: 15px; line-height: 24px; color: #52525b;">
  <%= t("passwords_mailer.reset.intro") %>
</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 24px;">
  <tr>
    <td align="center" style="background-color: #F43F8E; border: 2px solid #18181C;">
      <a href="<%= edit_password_url(@user.password_reset_token) %>"
         style="display: inline-block; padding: 14px 28px; font-size: 15px; font-weight: 700; color: #ffffff; text-decoration: none;">
        <%= t("passwords_mailer.reset.button") %>
      </a>
    </td>
  </tr>
</table>

<p style="margin: 0 0 8px; font-size: 13px; line-height: 20px; color: #71717a;">
  <%= t("passwords_mailer.reset.expires_html").html_safe %>
</p>

<p style="margin: 0; font-size: 13px; line-height: 20px; color: #a1a1aa;">
  <%= t("passwords_mailer.reset.fallback") %><br>
  <a href="<%= edit_password_url(@user.password_reset_token) %>" style="color: #DB2777; word-break: break-all;"><%= edit_password_url(@user.password_reset_token) %></a>
</p>
